{
  "name": "videoflow",
  "version": "0.1.0",
  "private": true,
  "description": "Local AI video production workspace for script cleanup, storyboard generation, voiceover, captions, and MP4 rendering.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-name/videoflow.git"
  },
  "keywords": [
    "ai-video",
    "storyboard",
    "tts",
    "minimax",
    "openai-compatible",
    "ffmpeg"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "npm run client:build && node app/server.js",
    "start": "node app/server.js",
    "check": "tsc --noEmit -p app/client/tsconfig.json && node --check app/server.js && node --check app/server/config.js",
    "client:dev": "vite --config app/client/vite.config.ts --host 127.0.0.1 --port 5174",
    "client:build": "vite build --config app/client/vite.config.ts"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "plyr": "^3.8.4",
    "postcss": "^8.5.14",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "wavesurfer.js": "^7.12.8"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  }
}
